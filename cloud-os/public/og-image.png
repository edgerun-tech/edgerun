<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="ogGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e40af"/>
      <stop offset="50%" style="stop-color:#2563eb"/>
      <stop offset="100%" style="stop-color:#3b82f6"/>
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="1200" height="630" fill="url(#ogGrad)"/>
  
  <!-- Grid pattern -->
  <g stroke="white" stroke-width="1" opacity="0.1">
    <line x1="0" y1="100" x2="1200" y2="100"/>
    <line x1="0" y1="200" x2="1200" y2="200"/>
    <line x1="0" y1="300" x2="1200" y2="300"/>
    <line x1="0" y1="400" x2="1200" y2="400"/>
    <line x1="0" y1="500" x2="1200" y2="500"/>
    <line x1="100" y1="0" x2="100" y2="630"/>
    <line x1="200" y1="0" x2="200" y2="630"/>
    <line x1="300" y1="0" x2="300" y2="630"/>
    <line x1="400" y1="0" x2="400" y2="630"/>
    <line x1="500" y1="0" x2="500" y2="630"/>
    <line x1="600" y1="0" x2="600" y2="630"/>
    <line x1="700" y1="0" x2="700" y2="630"/>
    <line x1="800" y1="0" x2="800" y2="630"/>
    <line x1="900" y1="0" x2="900" y2="630"/>
    <line x1="1000" y1="0" x2="1000" y2="630"/>
    <line x1="1100" y1="0" x2="1100" y2="630"/>
  </g>
  
  <!-- Logo -->
  <rect x="100" y="215" width="200" height="200" rx="40" fill="white" opacity="0.15"/>
  <path d="M250 290H170a40 40 0 0 0-35 60A36 36 0 0 0 150 380h100a30 30 0 0 0 0-60v-30z" fill="white"/>
  <circle cx="220" cy="325" r="16" fill="white" opacity="0.3"/>
  
  <!-- Title -->
  <text x="100" y="500" font-family="system-ui, -apple-system, sans-serif" font-size="72" font-weight="bold" fill="white">
    CloudOS
  </text>
  
  <!-- Subtitle -->
  <text x="100" y="550" font-family="system-ui, -apple-system, sans-serif" font-size="32" fill="white" opacity="0.9">
    Unified Cloud Operating System
  </text>
  
  <!-- URL -->
  <text x="100" y="590" font-family="system-ui, -apple-system, sans-serif" font-size="24" fill="white" opacity="0.7">
    cloud-os.kensservices.workers.dev
  </text>
</svg>
