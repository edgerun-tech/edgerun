<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1280 720">
  <defs>
    <linearGradient id="screenGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e40af"/>
      <stop offset="100%" style="stop-color:#2563eb"/>
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="1280" height="720" fill="url(#screenGrad)"/>
  
  <!-- Mock UI -->
  <rect x="50" y="50" width="1180" height="620" rx="12" fill="#0f172a" opacity="0.9"/>
  
  <!-- Intent Bar -->
  <rect x="80" y="80" width="1120" height="80" rx="8" fill="#1e293b"/>
  <rect x="100" y="100" width="800" height="40" rx="6" fill="#334155"/>
  <circle cx="1040" cy="120" r="20" fill="#3b82f6"/>
  
  <!-- Windows -->
  <rect x="80" y="200" width="400" height="300" rx="8" fill="#1e293b"/>
  <rect x="100" y="220" width="360" height="30" rx="4" fill="#334155"/>
  <rect x="100" y="270" width="360" height="200" rx="4" fill="#334155" opacity="0.5"/>
  
  <rect x="520" y="200" width="400" height="300" rx="8" fill="#1e293b"/>
  <rect x="540" y="220" width="360" height="30" rx="4" fill="#334155"/>
  <rect x="540" y="270" width="360" height="200" rx="4" fill="#334155" opacity="0.5"/>
  
  <rect x="960" y="200" width="240" height="300" rx="8" fill="#1e293b"/>
  <rect x="980" y="220" width="200" height="30" rx="4" fill="#334155"/>
  <rect x="980" y="270" width="200" height="200" rx="4" fill="#334155" opacity="0.5"/>
  
  <!-- Dock -->
  <rect x="440" y="640" width="400" height="60" rx="12" fill="#1e293b"/>
  <circle cx="480" cy="670" r="20" fill="#3b82f6"/>
  <circle cx="540" cy="670" r="20" fill="#10b981"/>
  <circle cx="600" cy="670" r="20" fill="#f59e0b"/>
  <circle cx="660" cy="670" r="20" fill="#ef4444"/>
  <circle cx="720" cy="670" r="20" fill="#8b5cf6"/>
  <circle cx="780" cy="670" r="20" fill="#ec4899"/>
  
  <!-- Title -->
  <text x="640" y="450" font-family="system-ui, -apple-system, sans-serif" font-size="48" font-weight="bold" fill="white" text-anchor="middle">
    CloudOS
  </text>
  <text x="640" y="500" font-family="system-ui, -apple-system, sans-serif" font-size="24" fill="white" opacity="0.8" text-anchor="middle">
    Unified Cloud Operating System
  </text>
</svg>
