#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROGRAM_ID="AgjxA2CoMmmWXrcsJtvvpmqdRHLVHrhYf6DAuBCL4s5T"
LEDGER_DIR="$ROOT_DIR/.anchor/manual-test-ledger"
RPC_URL="http://127.0.0.1:8899"
WS_URL="ws://127.0.0.1:8900"
VALIDATOR_LOG="$LEDGER_DIR/validator.log"

mkdir -p "$LEDGER_DIR"

cleanup() {
  if [[ -n "${VALIDATOR_PID:-}" ]] && kill -0 "$VALIDATOR_PID" 2>/dev/null; then
    kill "$VALIDATOR_PID" 2>/dev/null || true
    wait "$VALIDATOR_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT INT TERM

cd "$ROOT_DIR"

./scripts/anchor-local build >/dev/null

solana-test-validator \
  --reset \
  --ledger "$LEDGER_DIR" \
  --rpc-port 8899 \
  --faucet-port 9900 \
  --bpf-program "$PROGRAM_ID" "$ROOT_DIR/target/deploy/edgerun.so" \
  >"$VALIDATOR_LOG" 2>&1 &
VALIDATOR_PID=$!

for _ in $(seq 1 60); do
  if solana cluster-version --url "$RPC_URL" >/dev/null 2>&1; then
    break
  fi
  sleep 0.5
done

if ! solana cluster-version --url "$RPC_URL" >/dev/null 2>&1; then
  echo "validator did not become ready; check $VALIDATOR_LOG" >&2
  exit 1
fi

ANCHOR_PROVIDER_URL="$RPC_URL" \
ANCHOR_WALLET="$ROOT_DIR/.solana/id.json" \
ANCHOR_WS_URL="$WS_URL" \
bunx ts-mocha -p ./tsconfig.json -t 1000000 tests/**/*.ts
