#!/usr/bin/env bash
set -euo pipefail

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SCRIPT_SOURCE" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
  SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
  [[ "$SCRIPT_SOURCE" != /* ]] && SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PROGRAM_DIR="$ROOT_DIR/program"

usage() {
  cat <<'EOF'
EdgeRun project CLI

Usage:
  scripts/edgerun doctor
  scripts/edgerun setup [--install-missing]
  scripts/edgerun build [workspace|program|all]
  scripts/edgerun test [workspace|runtime|integration|e2e|rotation|program|all]
  scripts/edgerun run [fuzz-weekly|replay-corpus]
  scripts/edgerun all

Examples:
  scripts/edgerun doctor
  scripts/edgerun setup --install-missing
  scripts/edgerun build all
  scripts/edgerun test integration
  scripts/edgerun run replay-corpus
EOF
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

banner() {
  echo "==> $*"
}

check_cmd() {
  local cmd="$1"
  local label="$2"
  if have_cmd "$cmd"; then
    local ver
    ver="$("$cmd" --version 2>/dev/null | head -n1 || true)"
    echo "[ok]   $label ${ver:+($ver)}"
  else
    echo "[miss] $label"
  fi
}

doctor() {
  banner "toolchain check"
  check_cmd cargo "Rust cargo"
  check_cmd rustc "Rust compiler"
  check_cmd rustup "Rustup"
  check_cmd bun "Bun"
  check_cmd anchor "Anchor CLI"
  check_cmd solana "Solana CLI"
  check_cmd solana-test-validator "Solana test validator"
  check_cmd cargo-fuzz "cargo-fuzz"
  check_cmd python3 "Python3"
  check_cmd curl "curl"
}

setup() {
  local install_missing=0
  if [[ "${1:-}" == "--install-missing" ]]; then
    install_missing=1
  elif [[ -n "${1:-}" ]]; then
    echo "unknown setup option: $1" >&2
    exit 1
  fi

  banner "cargo fetch"
  (cd "$ROOT_DIR" && cargo fetch --locked)

  if have_cmd bun; then
    banner "program bun install"
    (cd "$PROGRAM_DIR" && bun install --frozen-lockfile)
  else
    echo "[warn] bun missing; skipping program dependency install"
  fi

  if have_cmd "$PROGRAM_DIR/scripts/cargo-local"; then
    if [[ ! -x "$PROGRAM_DIR/.cargo/bin/cargo-build-sbf" ]]; then
      if [[ "$install_missing" -eq 1 ]]; then
        banner "install local cargo-build-sbf (program/.cargo)"
        (cd "$PROGRAM_DIR" && ./scripts/cargo-local install cargo-build-sbf --version 4.0.0)
      else
        echo "[warn] cargo-build-sbf missing at program/.cargo/bin/cargo-build-sbf"
        echo "       run: scripts/edgerun setup --install-missing"
      fi
    fi
  fi

  if ! have_cmd cargo-fuzz; then
    if [[ "$install_missing" -eq 1 ]]; then
      banner "install cargo-fuzz"
      cargo install cargo-fuzz
    else
      echo "[warn] cargo-fuzz missing"
      echo "       run: scripts/edgerun setup --install-missing"
    fi
  fi

  banner "setup done"
}

build_workspace() {
  banner "cargo build workspace"
  (cd "$ROOT_DIR" && cargo build --workspace)
}

build_program() {
  if ! have_cmd bun; then
    echo "bun is required for program workflows" >&2
    exit 1
  fi
  banner "anchor build program"
  (cd "$PROGRAM_DIR" && ./scripts/anchor-local build)
}

build_cmd() {
  local target="${1:-workspace}"
  case "$target" in
    workspace) build_workspace ;;
    program) build_program ;;
    all) build_workspace; build_program ;;
    *) echo "unknown build target: $target" >&2; exit 1 ;;
  esac
}

test_workspace() {
  banner "cargo test workspace"
  (cd "$ROOT_DIR" && cargo test --workspace)
}

test_runtime() {
  banner "cargo test runtime"
  (cd "$ROOT_DIR" && cargo test -p edgerun-runtime)
}

test_integration() {
  banner "integration scheduler api"
  (cd "$ROOT_DIR" && ./scripts/integration_scheduler_api.sh)
}

test_e2e() {
  banner "integration e2e lifecycle"
  (cd "$ROOT_DIR" && ./scripts/integration_e2e_lifecycle.sh)
}

test_rotation() {
  banner "integration policy rotation"
  (cd "$ROOT_DIR" && ./scripts/integration_policy_rotation.sh)
}

test_program() {
  if ! have_cmd bun; then
    echo "bun is required for program tests" >&2
    exit 1
  fi
  banner "program bun local tests"
  (cd "$PROGRAM_DIR" && ./scripts/test-bun-local)
}

test_cmd() {
  local target="${1:-workspace}"
  case "$target" in
    workspace) test_workspace ;;
    runtime) test_runtime ;;
    integration) test_integration ;;
    e2e) test_e2e ;;
    rotation) test_rotation ;;
    program) test_program ;;
    all)
      test_runtime
      test_integration
      test_e2e
      test_rotation
      ;;
    *)
      echo "unknown test target: $target" >&2
      exit 1
      ;;
  esac
}

run_cmd() {
  local target="${1:-}"
  case "$target" in
    fuzz-weekly)
      banner "weekly fuzz"
      (cd "$ROOT_DIR" && ./scripts/weekly_fuzz.sh)
      ;;
    replay-corpus)
      banner "replay corpus"
      (cd "$ROOT_DIR" && ./scripts/run_replay_corpus.sh)
      ;;
    *)
      echo "unknown run target: ${target:-<empty>}" >&2
      exit 1
      ;;
  esac
}

all_cmd() {
  doctor
  setup
  build_workspace
  test_runtime
  test_integration
}

main() {
  local cmd="${1:-}"
  shift || true

  case "$cmd" in
    doctor) doctor "$@" ;;
    setup) setup "$@" ;;
    build) build_cmd "$@" ;;
    test) test_cmd "$@" ;;
    run) run_cmd "$@" ;;
    all) all_cmd "$@" ;;
    ""|-h|--help|help) usage ;;
    *)
      echo "unknown command: $cmd" >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
