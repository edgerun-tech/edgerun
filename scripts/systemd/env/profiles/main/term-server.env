EDGERUN_HARDWARE_MODE=allow-software
EDGERUN_TERM_SERVER_ADDR=127.0.0.1:5577
EDGERUN_TERM_PUBLIC_BASE_URL=http://127.0.0.1:5577
EDGERUN_ROUTE_CONTROL_BASE=https://api.edgerun.tech
# Optional additional URLs to announce for this route target (comma-separated).
# Useful to keep scheduler-facing backend URLs separate from public Access-protected hostnames.
# EDGERUN_ROUTE_REACHABLE_URLS=http://127.0.0.1:5577
# Optional wallet owner routing key (must match route signing key).
# EDGERUN_ROUTE_OWNER_PUBKEY=
# Optional base58 route owner secret key for scheduler route registration signatures.
# Accepts 32-byte seed or 64-byte Ed25519 keypair bytes (both base58 encoded).
# EDGERUN_ROUTE_OWNER_SECRET_KEY_B58=
# Optional mux token for /ws-mux auth.
# EDGERUN_TERM_MUX_TOKEN=
