{
  "name": "edgerun-site",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "clean": "rm -rf dist wiki",
    "build:css": "tailwindcss -i ./src/styles.css -o ./dist/assets/styles.css --minify",
    "build:js": "esbuild ./src/client.ts --format=esm --bundle=false --target=es2022 --outfile=./dist/assets/client.js",
    "build:html": "bun ./build.ts",
    "build": "bun run clean && mkdir -p dist/assets && bun run build:css && bun run build:js && bun run build:html"
  },
  "dependencies": {
    "solid-js": "^1.9.9"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.13",
    "esbuild": "^0.25.10",
    "tailwindcss": "^4.1.13"
  }
}
