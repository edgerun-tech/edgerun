# Keep localhost bridge for browser -> node-manager eventbus bridge.
EDGERUN_LOCAL_BRIDGE_LISTEN=127.0.0.1:7777

# Optional boot policy verification key.
# EDGERUN_BOOT_POLICY_VERIFY_KEY_B64URL=

# Optional Cloudflare Tunnel token for the "tunnel" compose profile.
# Start with:
#   scripts/node-manager-compose.sh up-tunnel
# CLOUDFLARE_TUNNEL_TOKEN=
