# SPDX-License-Identifier: Apache-2.0

# Keep localhost bridge for browser -> node-manager eventbus bridge.
EDGERUN_LOCAL_BRIDGE_LISTEN=127.0.0.1:7777

# Optional boot policy verification key.
# EDGERUN_BOOT_POLICY_VERIFY_KEY_B64URL=

# Optional MCP integration image overrides (used by local bridge MCP runtime).
# EDGERUN_MCP_GITHUB_IMAGE=ghcr.io/modelcontextprotocol/server-github:latest
# EDGERUN_MCP_WHATSAPP_IMAGE=
# EDGERUN_MCP_TELEGRAM_IMAGE=
# EDGERUN_MCP_SIGNAL_IMAGE=
# EDGERUN_MCP_DISCORD_IMAGE=
# EDGERUN_MCP_SLACK_IMAGE=
# EDGERUN_MCP_GOOGLE_MESSAGES_IMAGE=
# EDGERUN_MCP_GVOICE_IMAGE=
# EDGERUN_MCP_META_IMAGE=
# EDGERUN_MCP_GOOGLECHAT_IMAGE=
# EDGERUN_MCP_TWITTER_IMAGE=
# EDGERUN_MCP_BLUESKY_IMAGE=
# EDGERUN_MCP_IMESSAGE_IMAGE=
# EDGERUN_MCP_IMESSAGEGO_IMAGE=
# EDGERUN_MCP_LINKEDIN_IMAGE=
# EDGERUN_MCP_HEISENBRIDGE_IMAGE=

# Optional docker-log storage directory (edgerun-storage backend for
# /v1/local/docker/logs). Defaults to /var/lib/edgerun/storage.
# EDGERUN_DOCKER_LOGS_STORAGE_DIR=/var/lib/edgerun/storage

# Optional central event bus transport (NATS JetStream mirror for edge-internal bus).
# Leave unset to keep local-only event bus behavior.
# EDGERUN_EVENTBUS_NATS_URL=nats://127.0.0.1:4222
# EDGERUN_EVENTBUS_NATS_SUBJECT_ROOT=edgerun.events
# EDGERUN_EVENTBUS_NATS_STREAM=EDGERUN_EVENTS
# EDGERUN_INTEGRATION_TOPIC_ROOT=edgerun.integrations

# Optional mcp-syscall bind address used by the container service.
# MCP_SYSCALL_ADDR=127.0.0.1:7047

# Cloudflare Tunnel config-driven ingress files for the "tunnel" compose profile.
# Copy and edit config/cloudflared/node-manager-tunnel.yml.example, then place
# the tunnel credentials JSON at:
#   config/cloudflared/node-manager-tunnel-credentials.json
