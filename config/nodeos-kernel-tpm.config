# EdgeRun node minimum kernel config for TPM-backed PID1 boot.
# These must be built-in (=y), not modules (=m), so TPM is available before
# userspace/module loading.
CONFIG_TCG=y
CONFIG_TCG_TPM=y
CONFIG_TCG_TIS=y
CONFIG_TCG_TIS_CORE=y
CONFIG_TCG_CRB=y
CONFIG_TCG_TPM2=y
CONFIG_HW_RANDOM_TPM=y
