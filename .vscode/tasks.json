{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Deploy Frontend (Wrangler)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "cd \"${workspaceFolder}/frontend\" && bun run build && cd \"${workspaceFolder}\" && bunx --bun wrangler deploy"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
