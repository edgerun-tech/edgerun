{
  "name": "edgerun-frontend",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "clean": "rm -rf ../out/frontend/site ../out/frontend/wiki ../out/frontend/tmp ../out/frontend/generated",
    "brand:generate": "bun scripts/generate-brand-assets.mjs",
    "font:sync": "bun scripts/sync-fonts.mjs",
    "docs:generate": "bun scripts/generate-scheduler-docs.mjs",
    "runtime:web:build": "cargo run -p edgerun-cli -- --root .. ci --job build-runtime-web",
    "build:css": "mkdir -p ../out/frontend/site/assets && tailwindcss -i ./src/styles.css -o ../out/frontend/site/assets/styles.css --minify",
    "build:js": "timeout 20s bun ./scripts/build-client.mjs || node ./scripts/build-client.mjs",
    "build:html": "timeout 20s bun ./scripts/build-html.mjs || node ./scripts/build-html.mjs",
    "build:prod:validate": "bun scripts/validate-production-build.mjs",
    "build:prod": "bun run build:prod:validate && bun run build",
    "build": "bun run clean && bun run brand:generate && bun run font:sync && bun run docs:generate && bun run build:css && bun run build:js && bun run build:html",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "ws-schema:check": "bun scripts/check-control-panel-ws-schema.mjs",
    "test:e2e": "bun run e2e:run",
    "e2e:run": "bash ../scripts/e2e-frontend-all.sh",
    "e2e:core": "bash ../scripts/e2e-frontend-core.sh",
    "check": "bun run typecheck && bun run lint && bun run style-guide:check && bun run ws-schema:check",
    "style-guide:check": "bun scripts/enforce-style-guide.mjs",
    "e2e:compose": "bash ../scripts/e2e-local-terminal.sh"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@mdx-js/mdx": "^3.1.1",
    "@noble/ed25519": "^3.0.1",
    "@noble/hashes": "^1.8.0",
    "bs58": "^6.0.0",
    "markdown-it": "^14.1.1",
    "shiki": "^3.22.0",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@tailwindcss/cli": "^4.2.0",
    "@types/markdown-it": "^14.1.2",
    "bun-types": "^1.3.9",
    "cypress": "^15.10.0",
    "esbuild": "^0.25.12",
    "esbuild-plugin-solid": "^0.6.0",
    "eslint": "^9.39.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "^16.5.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  }
}
