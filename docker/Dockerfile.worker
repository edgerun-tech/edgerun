FROM rust:1-bookworm AS builder
WORKDIR /src
COPY . .
RUN cargo build --locked --release -p edgerun-worker

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /src/out/target/release/edgerun-worker /usr/local/bin/edgerun-worker
ENTRYPOINT ["/usr/local/bin/edgerun-worker"]
